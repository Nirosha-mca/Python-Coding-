ication and Access):\n","# a. Create a dictionary named student_marks that maps the names of five\n","# students to their marks (use scale of from 0 to 100).\n","# b. Access and print the mark of a specific student, of your choice.\n","# c. Add a new student \"Janani\" with a mark of 80 to the student_marks dictionary.\n","# d. Update the mark of any one older student to 82.\n","# e. Use the keys(), values(), and items() methods to print all keys, values, and\n","# key-value pairs in the student_marks dictionary."],"metadata":{"id":"HfS-naWyuuvC"},"execution_count":null,"outputs":[]},{"cell_type":"code","source":["student_marks = {\"arul\" : 80,\n","                 \"kumar\" : 75,\n","                \"priya\": 88,\n","                \"anu\" : 89,\n","                \"siva\" : 90}\n","\n","student_marks\n"],"metadata":{"id":"LeUiL3rTuurt","colab":{"base_uri":"https://localhost:8080/"},"executionInfo":{"status":"ok","timestamp":1774081536415,"user_tz":-330,"elapsed":50,"user":{"displayName":"Nirosha Periyasamy","userId":"08262521934158164573"}},"outputId":"1232070d-e541-43ab-db79-50d271bc5cfe"},"execution_count":11,"outputs":[{"output_type":"execute_result","data":{"text/plain":["{'arul': 80, 'kumar': 75, 'priya': 88, 'anu': 89, 'siva': 90}"]},"metadata":{},"execution_count":11}]},{"cell_type":"code","source":[" # b. Access and print the mark of a specific student, of your choice.\n"," print(\"mark of student:\", student_marks[\"priya\"])"],"metadata":{"id":"prOmh3MpuuiD","colab":{"base_uri":"https://localhost:8080/"},"executionInfo":{"status":"ok","timestamp":1774081209055,"user_tz":-330,"elapsed":14,"user":{"displayName":"Nirosha Periyasamy","userId":"08262521934158164573"}},"outputId":"0358ff1d-a686-475a-c410-fe1992835a54"},"execution_count":5,"outputs":[{"output_type":"stream","name":"stdout","text":["mark of student: 88\n"]}]},{"cell_type":"code","source":["# c. Add a new student \"Janani\" with a mark of 80 to the student_marks dictionary.\n","student_marks[\"janani\"] = 80\n","student_marks"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"m0Ihf_W8evF-","executionInfo":{"status":"ok","timestamp":1774081583411,"user_tz":-330,"elapsed":19,"user":{"displayName":"Nirosha Periyasamy","userId":"08262521934158164573"}},"outputId":"d9dae75e-9eee-44bb-c0dc-67a155e8a27b"},"execution_count":13,"outputs":[{"output_type":"execute_result","data":{"text/plain":["{'arul': 80, 'kumar': 75, 'priya': 88, 'anu': 89, 'siva': 90, 'janani': 80}"]},"metadata":{},"execution_count":13}]},{"cell_type":"code","source":["# d. Update the mark of any one older student to 82.\n","student_marks[\"kumar\"] = 82\n","student_marks"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"zwxfqw9ogDLY","executionInfo":{"status":"ok","timestamp":1774081637673,"user_tz":-330,"elapsed":10,"user":{"displayName":"Nirosha Periyasamy","userId":"08262521934158164573"}},"outputId":"d2e41031-60b5-4d01-d749-9330b3aad5c6"},"execution_count":15,"outputs":[{"output_type":"execute_result","data":{"text/plain":["{'arul': 80, 'kumar': 82, 'priya': 88, 'anu': 89, 'siva': 90, 'janani': 80}"]},"metadata":{},"execution_count":15}]},{"cell_type":"code","source":["# e. Use the keys(), values(), and items() methods to print all keys, values, and\n","# key-value pairs in the student_marks dictionary.\n","print(\"student names:\", student_marks.keys())\n","print(\"student marks:\", student_marks.values())\n","print(\"student key-value:\",student_marks.items())"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"Lv_QFf_MgDH2","executionInfo":{"status":"ok","timestamp":1774082138573,"user_tz":-330,"elapsed":12,"user":{"displayName":"Nirosha Periyasamy","userId":"08262521934158164573"}},"outputId":"b4cef57f-8cec-473f-d4d2-7df792332364"},"execution_count":20,"outputs":[{"output_type":"stream","name":"stdout","text":["student names: dict_keys(['arul', 'kumar', 'priya', 'anu', 'siva', 'janani'])\n","student marks: dict_values([80, 82, 88, 89, 90, 80])\n","student key-value: dict_items([('arul', 80), ('kumar', 82), ('priya', 88), ('anu', 89), ('siva', 90), ('janani', 80)])\n"]}]},{"cell_type":"code","source":["# Sets (Operations):\n","# a. Create a set called my_set with following values:\n","# ['a','e','i','o','u','a','a','i']\n","# Analyse the output and provide explanation for the same.\n","# b. Attempt to change the value of my_set[4] = 's'. If code throws an error, provide\n","# an explanation.\n","# c. Create two sets:\n","# set1 with values: {1, 3, 5, 7, 9}\n","# set2 with values: {2, 3, 5, 8, 10}\n","# d. Compute and print the union and intersection of set1 and set2.\n","\n","#  a. Create a set called my_set with following values:\n","# ['a','e','i','o','u','a','a','i']\n","my_set = {'a','e','i','o','u','a','a','i'}\n","print(my_set)\n","type(my_set)\n","\n"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"hqEOWiCBgDE6","executionInfo":{"status":"ok","timestamp":1774082655755,"user_tz":-330,"elapsed":11,"user":{"displayName":"Nirosha Periyasamy","userId":"08262521934158164573"}},"outputId":"fb8185dd-3606-4de1-d0ef-250cbb38d09e"},"execution_count":23,"outputs":[{"output_type":"stream","name":"stdout","text":["{'e', 'o', 'u', 'i', 'a'}\n"]},{"output_type":"execute_result","data":{"text/plain":["set"]},"metadata":{},"execution_count":23}]},{"cell_type":"code","source":["#  b. Attempt to change the value of my_set[4] = 's'. If code throws an error, provide\n","# an explanation.\n","\n","my_set[4] = ('s')\n","my_set"],"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":193},"id":"5EpMBpv4kY3B","executionInfo":{"status":"error","timestamp":1774083003877,"user_tz":-330,"elapsed":23,"user":{"displayName":"Nirosha Periyasamy","userId":"08262521934158164573"}},"outputId":"b6e021f1-491f-4c39-b923-c0c524f7373d"},"execution_count":26,"outputs":[{"output_type":"error","ename":"TypeError","evalue":"'set' object does not support item assignment","traceback":["\u001b[0;31m---------------------------------------------------------------------------\u001b[0m","\u001b[0;31mTypeError\u001b[0m                                 Traceback (most recent call last)","\u001b[0;32m/tmp/ipykernel_1516/872471775.py\u001b[0m in \u001b[0;36m<cell line: 0>\u001b[0;34m()\u001b[0m\n\u001b[1;32m      2\u001b[0m \u001b[0;31m# an explanation.\u001b[0m\u001b[0;34m\u001b[0m\u001b[0;34m\u001b[0m\u001b[0m\n\u001b[1;32m      3\u001b[0m \u001b[0;34m\u001b[0m\u001b[0m\n\u001b[0;32m----> 4\u001b[0;31m \u001b[0mmy_set\u001b[0m\u001b[0;34m[\u001b[0m\u001b[0;36m4\u001b[0m\u001b[0;34m]\u001b[0m \u001b[0;34m=\u001b[0m \u001b[0;34m(\u001b[0m\u001b[0;34m's'\u001b[0m\u001b[0;34m)\u001b[0m\u001b[0;34m\u001b[0m\u001b[0;34m\u001b[0m\u001b[0m\n\u001b[0m\u001b[1;32m      5\u001b[0m \u001b[0mmy_set\u001b[0m\u001b[0;34m\u001b[0m\u001b[0;34m\u001b[0m\u001b[0m\n","\u001b[0;31mTypeError\u001b[0m: 'set' object does not support item assignment"]}]},{"cell_type":"code","source":["# c. Create two sets:\n","# set1 with values: {1, 3, 5, 7, 9}\n","# set2 with values: {2, 3, 5, 8, 10}\n","\n","set1 = {1,2,5,7,9}\n","set2 = {2,3,5,8,9}\n","print(set1,set2)\n","type(set1)"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"2WKOPve4kYzZ","executionInfo":{"status":"ok","timestamp":1774083296883,"user_tz":-330,"elapsed":11,"user":{"displayName":"Nirosha Periyasamy","userId":"08262521934158164573"}},"outputId":"d37610a1-0119-49fa-9870-ebbb5f0ee77e"},"execution_count":29,"outputs":[{"output_type":"stream","name":"stdout","text":["{1, 2, 5, 7, 9} {2, 3, 5, 8, 9}\n"]},{"output_type":"execute_result","data":{"text/plain":["set"]},"metadata":{},"execution_count":29}]},{"cell_type":"code","source":["\n","# d. Compute and print the union and intersection of set1 and set2.\n","# UNION\n","all_set = set1 | set2\n","print(all_set)\n"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"vY9UNUuokYwk","executionInfo":{"status":"ok","timestamp":1774083542852,"user_tz":-330,"elapsed":10,"user":{"displayName":"Nirosha Periyasamy","userId":"08262521934158164573"}},"outputId":"e668f85f-355b-408c-b2d7-bf580c058bec"},"execution_count":31,"outputs":[{"output_type":"stream","name":"stdout","text":["{1, 2, 3, 5, 7, 8, 9}\n"]}]},{"cell_type":"code","source":["# INTERSECTION\n","common_set = set1 & set2\n","print(common_set)\n"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"jUWjBrzagC3Z","executionInfo":{"status":"ok","timestamp":1774083589962,"user_tz":-330,"elapsed":17,"user":{"displayName":"Nirosha Periyasamy","userId":"08262521934158164573"}},"outputId":"992883bf-115f-4eae-d039-89570a4516e3"},"execution_count":32,"outputs":[{"output_type":"stream","name":"stdout","text":["{9, 2, 5}\n"]}]},{"cell_type":"code","source":["# Operators & Conditional Statements :\n","# (IF, ELIF, ELSE)\n","# Performance Category Program:\n","# 1. Prompt user for Input. Score range should be from 0 to 10 (both inclusive).\n","# 2. Find the performance category based on the input score using following criteria:\n","# a. Above Average: Score greater than 7\n","# b. Average: Score between 4 and 7(both inclusive)\n","# c. Below Average: Score lesser than 4\n","# 3. Output: Print the Performance category\n","\n","# 4. Additional Step: You can give a prompt of your choice to each category.\n","# For eg: If score below average “Need to Improve your performance, consistent\n","# practice will lead to better results”.\n","\n","score = int(input(\"enter your score (0 to 10) :\"))\n","if score > 7 :\n","     print(\"performance category: above average\")\n","elif score >=4 and score <=7 :\n","     print(\"performance category :average\")\n","     print(\"good effort ! keep practicing, there is room for improvement\")\n","else:\n","    print(\"performance category : below average\")\n","    print(\"need to improve your performance , consistent practice will lead to better result.\")\n","\n","\n"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"PyAZlkdKn2Kk","executionInfo":{"status":"ok","timestamp":1774087143490,"user_tz":-330,"elapsed":3090,"user":{"displayName":"Nirosha Periyasamy","userId":"08262521934158164573"}},"outputId":"9d668cdd-15fc-466a-9fd5-e24315c3a899"},"execution_count":74,"outputs":[{"output_type":"stream","name":"stdout","text":["enter your score (0 to 10) :3\n","performance category : below average\n","need to improve your performance , consistent practice will lead to better result.\n"]}]},{"cell_type":"code","source":[],"metadata":{"id":"frFo9qUUn2HC"},"execution_count":null,"outputs":[]},{"cell_type":"code","source":[],"metadata":{"id":"QgL0k0Mnn2Eb"},"execution_count":null,"outputs":[]},{"cell_type":"code","source":[],"metadata":{"id":"XnnzaMhBn2B0"},"execution_count":null,"outputs":[]}],"metadata":{"colab":{"provenance":[{"file_id":"/v2/external/notebooks/intro.ipynb","timestamp":1774035503351}]},"kernelspec":{"display_name":"Python 3","name":"python3"}},"nbformat":4,"nbformat_minor":0}